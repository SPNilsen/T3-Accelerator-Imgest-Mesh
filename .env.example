# Imgest-Mesh local dev — copy to .env (already gitignored)
# Set SKIP_SSL_VERIFY=true on corporate networks with SSL inspection (e.g. Netskope).
# Leave false or unset for CI / prod builds.

COMPOSE_PROJECT_NAME=imgest-mesh
SKIP_SSL_VERIFY=false

# Path to a sibling clone of T3-Accelerator-JNJ-Armor used by the
# jnj-armor-docs service. Default assumes both repos are cloned side-by-side
# under the same parent directory. Override here if your layout differs.
JNJ_ARMOR_REPO_PATH=../T3-Accelerator-JNJ-Armor
