  "layer": [
    {
      "transform": [
        { "bin": { "maxbins": 25 }, "field": "hours", "as": ["bin_start", "bin_end"] },
        { "aggregate": [{ "op": "count", "as": "count" }], "groupby": ["bin_start", "bin_end"] },
        { "calculate": "datum.bin_end - datum.bin_start", "as": "bin_width" },
        { "calculate": "datum.count / (90 * datum.bin_width)", "as": "density" }
      ],
      "mark": { "type": "bar", "opacity": 0.35 },
      "encoding": {
        "x": { "field": "bin_start", "type": "quantitative", "title": "Tool lifetime (hours)", "axis": { "format": ",.0f" } },
        "x2": { "field": "bin_end" },
        "y": { "field": "density", "type": "quantitative", "title": "Density" },
        "tooltip": [
          { "field": "bin_start", "type": "quantitative", "title": "From (hrs)", "format": ",.0f" },
          { "field": "bin_end", "type": "quantitative", "title": "To (hrs)", "format": ",.0f" },
          { "field": "count", "type": "quantitative", "title": "Count" },
          { "field": "density", "type": "quantitative", "title": "Density", "format": ".3e" }
        ]
      }
    },
    {
      "data": { "sequence": { "start": 100, "stop": 60000, "step": 200 } },
      "transform": [
        { "calculate": "datum.data", "as": "t" },
        { "calculate": "(1.7/12000)*pow(datum.t/12000,0.7)*exp(-pow(datum.t/12000,1.7))", "as": "pdf" },
        { "calculate": "'Weibull PDF (β=1.7, η=12000)'", "as": "model" }
      ],
      "mark": { "type": "line", "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "t", "type": "quantitative" },
        "y": { "field": "pdf", "type": "quantitative" },
        "detail": { "field": "model" },
        "tooltip": [
          { "field": "model", "type": "nominal", "title": "Model" },
          { "field": "t", "type": "quantitative", "title": "Hours", "format": ",.0f" },
          { "field": "pdf", "type": "quantitative", "title": "Density", "format": ".3e" }
        ]
      }
    },
    {
      "data": { "sequence": { "start": 100, "stop": 60000, "step": 200 } },
      "transform": [
        { "calculate": "datum.data", "as": "t" },
        { "calculate": "(1/(datum.t*0.55*2.50662827463))*exp(-pow(log(datum.t)-8.8,2)/(2*pow(0.55,2)))", "as": "pdf" },
        { "calculate": "'Lognormal PDF (μ=8.8, σ=0.55)'", "as": "model" }
      ],
      "mark": { "type": "line", "strokeDash": [6, 4], "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "t", "type": "quantitative" },
        "y": { "field": "pdf", "type": "quantitative" },
        "detail": { "field": "model" },
        "tooltip": [
          { "field": "model", "type": "nominal", "title": "Model" },
          { "field": "t", "type": "quantitative", "title": "Hours", "format": ",.0f" },
          { "field": "pdf", "type": "quantitative", "title": "Density", "format": ".3e" }
        ]
      }
    },
    {
      "data": { "sequence": { "start": 100, "stop": 60000, "step": 200 } },
      "transform": [
        { "calculate": "datum.data", "as": "t" },
        { "calculate": "(pow(datum.t,2)*exp(-datum.t/4000))/(pow(4000,3)*2)", "as": "pdf" },
        { "calculate": "'Gamma/Erlang PDF (k=3, θ=4000)'", "as": "model" }
      ],
      "mark": { "type": "line", "strokeDash": [2, 2], "strokeWidth": 2 },
      "encoding": {
        "x": { "field": "t", "type": "quantitative" },
        "y": { "field": "pdf", "type": "quantitative" },
        "detail": { "field": "model" },
        "tooltip": [
          { "field": "model", "type": "nominal", "title": "Model" },
          { "field": "t", "type": "quantitative", "title": "Hours", "format": ",.0f" },
          { "field": "pdf", "type": "quantitative", "title": "Density", "format": ".3e" }
        ]
      }
    },
    {
      "mark": { "type": "tick", "thickness": 1, "size": 10, "opacity": 0.6 },
      "encoding": {
        "x": { "field": "hours", "type": "quantitative" },
        "y": { "value": 0 },
        "tooltip": [{ "field": "hours", "type": "quantitative", "title": "Observed lifetime (hrs)", "format": ",.0f" }]
      }
    }
  ],
  "config": { "axis": { "labelFontSize": 11, "titleFontSize": 12 } }
}
